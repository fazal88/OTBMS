{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": true,
    "outDir": "lib",
    "rootDir": "src",
    "preserveConstEnums": true,
    "removeComments": true,
    "sourceMap": true,
    "target": "es2018",
    "lib": ["es2018"],
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
